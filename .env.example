# Example environment variables for svai
# Copy this file to .env (or export these vars in your shell) and fill in values.
# Do NOT commit the real .env file.

# API keys (supply via environment variables / .env)

# Fundamentals (pick one; FMP recommended — 250 req/day free tier)
Providers__FmpApiKey=
Providers__AlphaVantageApiKey=

# Macro (FRED — generous free tier)
Providers__FredApiKey=

# Options (Polygon — free tier may not include options snapshots)
Providers__PolygonApiKey=